---
import { mainNav, site } from '../data/site';
import { telHref } from '../data/nap';

const phoneLink = telHref();
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-[#1a0000]/90 backdrop-blur-md supports-[backdrop-filter]:bg-[#1a0000]/75"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 md:px-6">
    <a href="/" class="group flex items-center gap-3 leading-tight" aria-label={site.name}>
      <img
        src={site.logoMark}
        alt={`${site.name} mark`}
        width="365"
        height="375"
        class="h-11 w-auto shrink-0 object-contain drop-shadow-[0_1px_6px_rgba(0,0,0,0.35)] sm:h-12"
      />
      <span class="flex flex-col">
        <span class="font-display text-base font-bold uppercase tracking-tight text-white sm:text-lg">
          {site.nameLine1}
        </span>
        <span class="font-display text-[11px] font-semibold uppercase tracking-[0.18em] text-white/70 sm:text-xs">
          {site.nameLine2}
        </span>
      </span>
    </a>
    <nav class="hidden items-center gap-0.5 lg:flex" aria-label="Main">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-2.5 py-2 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white xl:px-3"
          >
            {item.label}
          </a>
        ))
      }
      {
        phoneLink && (
          <a
            href={phoneLink}
            class="ml-1 rounded-lg px-2.5 py-2 text-sm font-semibold text-white hover:bg-white/10 xl:px-3"
          >
            Call
          </a>
        )
      }
      <a
        href="/contact/"
        class="ml-1 inline-flex items-center rounded-full bg-white px-4 py-2.5 text-sm font-bold uppercase tracking-wider text-[#1a0000] shadow-lift transition hover:bg-white/90 xl:px-5"
      >
        Book a call
      </a>
    </nav>
    <details class="relative lg:hidden">
      <summary
        class="cursor-pointer list-none rounded-full border border-white/30 bg-white/10 px-4 py-2 text-sm font-semibold text-white backdrop-blur"
      >
        Menu
      </summary>
      <div
        class="absolute right-0 z-50 mt-2 max-h-[min(70vh,520px)] w-64 overflow-y-auto rounded-2xl border border-white/10 bg-[#660000] p-2 shadow-lift"
      >
        {
          mainNav.map((item) => (
            <a
              href={item.href}
              class="block rounded-xl px-3 py-2.5 text-sm font-medium text-white/85 hover:bg-white/10 hover:text-white"
            >
              {item.label}
            </a>
          ))
        }
        {
          phoneLink && (
            <a
              href={phoneLink}
              class="block rounded-xl px-3 py-2.5 text-sm font-semibold text-white hover:bg-white/10"
            >
              Call
            </a>
          )
        }
        <a
          href="/contact/"
          class="mt-1 block rounded-xl bg-white px-3 py-2.5 text-center text-sm font-bold uppercase tracking-wider text-[#1a0000]"
        >
          Book a call
        </a>
      </div>
    </details>
  </div>
</header>
