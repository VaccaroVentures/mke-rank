---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { site } from '../../data/site';
import { localCities, getLocalCity } from '../../data/local-cities';
import { localBusinessSchema, breadcrumbSchema, webPageSchema } from '../../data/seo';

export function getStaticPaths() {
  return localCities.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const city = slug ? getLocalCity(slug) : undefined;

if (!city) {
  return Astro.redirect('/areas/');
}

const pageUrl = new URL(`/areas/${city.slug}/`, site.url).toString();
const jsonLd = [
  localBusinessSchema(),
  webPageSchema({
    name: city.seoTitle,
    description: city.seoDescription,
    url: pageUrl,
    cityState: `${city.name}, WI`,
  }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Service areas', path: '/areas/' },
    { name: `${city.name}, WI`, path: `/areas/${city.slug}/` },
  ]),
];
---

<BaseLayout title={city.seoTitle} description={city.seoDescription} keywords={city.keywords.join(', ')} jsonLd={jsonLd}>
  <article>
    <header class="border-b border-badger/8 bg-gradient-to-b from-paper to-paper-dim">
      <div class="mx-auto max-w-6xl px-4 py-14 md:px-6 md:py-20">
        <nav class="text-xs font-medium text-badger/50" aria-label="Breadcrumb">
          <ol class="flex flex-wrap gap-x-2 gap-y-1">
            <li><a href="/" class="hover:text-badger">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/areas/" class="hover:text-badger">Service areas</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-badger">{city.name}, WI</li>
          </ol>
        </nav>
        <p class="mt-8 text-[11px] font-bold uppercase tracking-[0.22em] text-badger/45">
          {site.name} · {city.countyName}
        </p>
        <h1 class="mt-3 max-w-4xl font-display text-4xl font-semibold leading-tight text-ink md:text-5xl">
          AI automation &amp; local SEO for businesses in {city.name}, Wisconsin
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-badger/80">{city.seoDescription}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="inline-flex rounded-full bg-ink px-7 py-3 text-sm font-semibold text-paper shadow-card hover:bg-ink-soft"
          >
            Book a call
          </a>
          <a
            href={`/locations/${city.countySlug}/`}
            class="inline-flex rounded-full border border-badger/15 bg-paper px-7 py-3 text-sm font-semibold text-ink hover:border-badger/30"
          >
            {city.countyName} overview
          </a>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-6xl px-4 py-14 md:px-6 md:py-16">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-14">
        <div class="lg:col-span-7">
          {
            city.sections.map((section) => (
              <section class="mb-12 last:mb-0">
                <h2 class="font-display text-2xl font-semibold text-ink">{section.heading}</h2>
                <p class="mt-4 leading-relaxed text-badger/80">{section.body}</p>
              </section>
            ))
          }
          <div class="mt-12 rounded-2xl border border-badger/10 bg-paper-dim/40 p-6">
            <h2 class="font-display text-lg font-semibold text-ink">Related services</h2>
            <ul class="mt-4 flex flex-wrap gap-3 text-sm font-medium">
              <li>
                <a class="text-accent hover:underline" href="/services/ai-automation-consulting/">AI consulting</a>
              </li>
              <li>
                <a class="text-accent hover:underline" href="/services/workflow-business-automation/">Workflow automation</a>
              </li>
              <li>
                <a class="text-accent hover:underline" href="/services/local-seo-services/">Local SEO</a>
              </li>
              <li>
                <a class="text-accent hover:underline" href="/services/google-business-profile-ai/">Google Business Profile</a>
              </li>
            </ul>
          </div>
        </div>
        <div class="lg:col-span-5">
          <LeadForm
            formName={`lead-area-${city.slug}`}
            contextLabel={`${city.name}, WI — automation & local SEO`}
            heading={`Plan a project in ${city.name}`}
            subheading="Tell us your tools, service area, and what you want off your plate first."
          />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
