---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { homeVerticals, site } from '../../data/site';
import { getHomeVertical } from '../../data/home-verticals';

export function getStaticPaths() {
  return homeVerticals.map((v) => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const detail = slug ? getHomeVertical(slug) : undefined;

if (!detail) {
  return Astro.redirect('/home-services/');
}

const formName = `lead-${detail.slug}`;
---

<BaseLayout
  title={`Local SEO for ${detail.title} Contractors`}
  description={`${detail.intro.slice(0, 155)}…`}
>
  <article class="mx-auto max-w-6xl px-4 py-14 md:px-6 md:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-badger/55">
      {site.name} · {detail.title}
    </p>
    <h1 class="mt-3 max-w-3xl font-display text-4xl font-bold text-badger">{detail.headline}</h1>
    <p class="mt-6 max-w-3xl text-lg text-badger/85 leading-relaxed">{detail.intro}</p>

    <div class="mt-12 grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-10">
        <section>
          <h2 class="font-display text-2xl font-bold text-badger">What we see go wrong</h2>
          <ul class="mt-4 list-disc space-y-2 pl-5 marker:text-gold">
            {detail.painPoints.map((p) => <li>{p}</li>)}
          </ul>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-badger">Local playbook highlights</h2>
          <div class="mt-4 space-y-4">
            {
              detail.localPlaybook.map((item) => (
                <div class="rounded-xl border border-cream-200 bg-cream-50 p-4">
                  <h3 class="font-semibold text-badger">{item.title}</h3>
                  <p class="mt-1 text-sm text-badger/80">{item.body}</p>
                </div>
              ))
            }
          </div>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-badger">Where AI fits (safely)</h2>
          <ul class="mt-4 list-disc space-y-2 pl-5 marker:text-gold">
            {detail.aiAngle.map((a) => <li>{a}</li>)}
          </ul>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-badger">Example search themes</h2>
          <p class="mt-2 text-sm text-badger/70">
            Illustrative phrases homeowners use—your market may vary by neighborhood.
          </p>
          <ul class="mt-4 flex flex-wrap gap-2">
            {
              detail.keywords.map((k) => (
                <li class="rounded-full bg-cream-200/80 px-3 py-1 text-sm text-badger">{k}</li>
              ))
            }
          </ul>
        </section>
      </div>

      <div class="lg:col-span-1">
        <LeadForm
          formName={formName}
          contextLabel={`${detail.title} local SEO (${site.region})`}
          heading={`Book a strategy call for ${detail.title}`}
          subheading="We will review your GBP, top competitors, and the fastest wins in your service area."
        />
      </div>
    </div>
  </article>
</BaseLayout>
