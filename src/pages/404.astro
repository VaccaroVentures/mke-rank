---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you requested could not be found.">
  <div class="mx-auto max-w-xl px-4 py-24 text-center md:px-6">
    <h1 class="font-display text-4xl font-bold text-badger">404</h1>
    <p class="mt-4 text-badger/80">That page is not on the map—literally or figuratively.</p>
    <a href="/" class="mt-8 inline-flex rounded-lg bg-badger px-6 py-3 text-sm font-semibold text-cream-50 hover:bg-badger-600">
      Go home
    </a>
  </div>
</BaseLayout>
