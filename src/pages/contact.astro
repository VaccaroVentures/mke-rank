---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { site } from '../data/site';
import { nap, formatNapAddressLines, telHref } from '../data/nap';
import { localBusinessSchema } from '../data/seo';

const phoneLink = telHref();
const addressLines = formatNapAddressLines();
const hoursLabel = nap.openingHours
  .map((h) => {
    const days =
      h.dayOfWeek.length >= 5 && h.dayOfWeek.includes('Friday') ? 'Monday–Friday' : h.dayOfWeek.join(', ');
    return `${days}: ${h.opens}–${h.closes} (${nap.timeZone})`;
  })
  .join(' · ');
---

<BaseLayout
  title="Contact | SE Wisconsin Business Automation"
  description="Contact SE Wisconsin Business Automation: phone, email, hours, and office details for AI automation and local SEO across Milwaukee, Waukesha, Racine, Kenosha, Ozaukee, Washington, and Walworth Counties—match this NAP to your Google Business Profile."
  keywords="contact SE Wisconsin Business Automation, AI consultant Wisconsin, Milwaukee automation, southeastern Wisconsin business"
  jsonLd={[localBusinessSchema()]}
>
  <div class="mx-auto max-w-6xl px-4 py-14 md:px-6 md:py-20">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-badger/45">Contact</p>
        <h1 class="mt-4 font-display text-4xl font-semibold text-ink md:text-5xl">
          Tell us what is eating your week
        </h1>
        <p class="mt-5 text-lg text-badger/80">
          Share your tools, your service area, and the one process that breaks most often. We typically reply within
          one business day.
        </p>

        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-badger/10 bg-paper p-6 shadow-card">
            <h2 class="text-[11px] font-bold uppercase tracking-[0.2em] text-badger/45">NAP</h2>
            <p class="mt-3 font-display text-xl font-semibold text-ink">{site.name}</p>
            <address class="mt-3 text-sm not-italic leading-relaxed text-badger/80">
              {addressLines.map((line) => (
                <span class="block">{line}</span>
              ))}
            </address>
            {phoneLink && (
              <a class="mt-3 block text-lg font-semibold text-badger hover:underline" href={phoneLink}>
                {nap.telephone}
              </a>
            )}
            <a class="mt-2 block font-medium text-badger hover:underline" href={`mailto:${site.email}`}>
              {site.email}
            </a>
          </div>

          <div class="rounded-2xl border border-badger/10 bg-paper-dim/40 p-6">
            <h2 class="text-sm font-semibold text-ink">Hours</h2>
            <p class="mt-2 text-sm text-badger/75">
              {hoursLabel}
            </p>
          </div>

          {
            nap.googleMapsEmbedUrl && (
              <div class="overflow-hidden rounded-2xl border border-badger/10 shadow-card">
                <iframe
                  title="Map — SE Wisconsin Business Automation"
                  src={nap.googleMapsEmbedUrl}
                  class="h-56 w-full"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  allowfullscreen
                />
              </div>
            )
          }

          {nap.googleMapsUrl && !nap.googleMapsEmbedUrl && (
            <a
              href={nap.googleMapsUrl}
              class="inline-flex text-sm font-semibold text-accent hover:underline"
              rel="noopener noreferrer"
              target="_blank"
            >
              Open in Google Maps →
            </a>
          )}
        </div>
      </div>
      <LeadForm
        formName="contact-general"
        contextLabel="SE Wisconsin Business Automation inquiry"
        heading="Request a call back"
        subheading="Working sessions and pilot planning—no jargon walls."
      />
    </div>
  </div>
</BaseLayout>
